# PostgreSQL connection. Prefer DATABASE_URL if available.
# Example:
# DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/customer_next_order
DATABASE_URL=

# Alternative fields if DATABASE_URL is empty.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=customer_next_order
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

